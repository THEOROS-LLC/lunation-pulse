---
import { ClientRouter } from 'astro:transitions';
import '../styles/global.css';
const { title = 'Lunar Pulse', description = 'A live lunation clock — the Moon\u2019s zodiacal position, phase, and the turning sky, kept to the arcminute in real time.' } = Astro.props;
const canonical = new URL(Astro.url.pathname, Astro.site);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="description" content={description} />
    <title>{title}</title>
    <link rel="canonical" href={canonical} />
    <meta name="theme-color" content="#160e33" />
    <meta property="og:type" content="website" />
    <meta property="og:site_name" content="Lunar Pulse" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <ClientRouter />
  </head>
  <body>
    <canvas id="stars" transition:persist="stars" aria-hidden="true"></canvas>
    <main class="stage">
      <slot />
    </main>
    <script>
      // Starfield — persisted canvas, idempotent init, rests when hidden.
      function initStars() {
        const c = document.getElementById('stars');
        if (!c || c.__init) return;
        c.__init = true;
        const ctx = c.getContext('2d');
        const reduced = matchMedia('(prefers-reduced-motion: reduce)').matches;
        const DPR = Math.min(2, window.devicePixelRatio || 1);
        let W = 0, H = 0, stars = [];
        function size() {
          W = innerWidth; H = innerHeight;
          c.width = W * DPR; c.height = H * DPR;
          c.style.width = W + 'px'; c.style.height = H + 'px';
          ctx.setTransform(DPR, 0, 0, DPR, 0, 0);
          stars = Array.from({ length: Math.round((W * H) / 9000) }, () => ({
            x: Math.random() * W, y: Math.random() * H,
            r: 0.3 + Math.random() * 1.25,
            p: Math.random() * Math.PI * 2,
            s: 0.4 + Math.random() * 1.1,
            tw: Math.random() < 0.35,
          }));
        }
        size();
        addEventListener('resize', size);
        let shoot = null;
        let nextShoot = performance.now() + 9000 + Math.random() * 24000;
        function draw(t) {
          ctx.clearRect(0, 0, W, H);
          for (const st of stars) {
            const a = st.tw ? 0.3 + 0.5 * Math.abs(Math.sin(st.p + (t / 1000) * st.s)) : 0.55;
            ctx.globalAlpha = a;
            ctx.fillStyle = '#dfe6ff';
            ctx.beginPath(); ctx.arc(st.x, st.y, st.r, 0, 6.2832); ctx.fill();
          }
          ctx.globalAlpha = 1;
          if (!reduced) {
            if (!shoot && t > nextShoot) {
              const x = Math.random() * W * 0.8 + W * 0.1;
              const y = Math.random() * H * 0.35;
              const ang = Math.PI * (0.72 + Math.random() * 0.16);
              shoot = { x, y, dx: Math.cos(ang), dy: -Math.sin(ang), t0: t };
            }
            if (shoot) {
              const life = (t - shoot.t0) / 700;
              if (life >= 1) { shoot = null; nextShoot = t + 16000 + Math.random() * 34000; }
              else {
                const d = life * 260, len = 90 * (1 - life * 0.4);
                const x2 = shoot.x + shoot.dx * d, y2 = shoot.y - shoot.dy * d;
                const g = ctx.createLinearGradient(x2 - shoot.dx * len, y2 + shoot.dy * len, x2, y2);
                g.addColorStop(0, 'rgba(223,230,255,0)');
                g.addColorStop(1, `rgba(240,244,255,${0.9 * (1 - life)})`);
                ctx.strokeStyle = g; ctx.lineWidth = 1.6;
                ctx.beginPath();
                ctx.moveTo(x2 - shoot.dx * len, y2 + shoot.dy * len);
                ctx.lineTo(x2, y2); ctx.stroke();
              }
            }
          }
        }
        if (reduced) { draw(0); return; }
        (function loop(t) {
          if (!document.hidden) draw(t);
          requestAnimationFrame(loop);
        })(0);
      }
      initStars();
      document.addEventListener('astro:page-load', initStars);
    </script>
  </body>
</html>
