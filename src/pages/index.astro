---
import Base from '../layouts/Base.astro';
import Cclc from '../components/Cclc.astro';
import { getLunation } from '../cclc/lunation.js';
const L = getLunation(new Date());
const sunIn = L.sunLon % 30;
const sunSign = ['Aries','Taurus','Gemini','Cancer','Leo','Virgo','Libra','Scorpio','Sagittarius','Capricorn','Aquarius','Pisces'][Math.floor(L.sunLon / 30)];
const pad = n => String(n).padStart(2, '0');
const skyNow = `The Moon is at ${L.deg}\u00b0${pad(L.arcmin)}\u2032 ${L.sign}, ${L.phase.toLowerCase()}. Sun at ${Math.floor(sunIn)}\u00b0${pad(Math.floor((sunIn % 1) * 60))}\u2032 ${sunSign}. Kept to the arcminute, every second.`;
const built = new Date().toISOString();
const ld = JSON.stringify({'@context':'https://schema.org','@graph':[
  {'@type':'WebSite','@id':'https://lunarpulse.ai/#site',name:'Lunar Pulse',url:'https://lunarpulse.ai/',description:'The sky, kept as a clock.'},
  {'@type':'WebApplication','@id':'https://lunarpulse.ai/#app',name:'Lunar Pulse',url:'https://lunarpulse.ai/',applicationCategory:'ReferenceApplication',dateModified:built}
]});
---
<Base title="Lunar Pulse">
  <Cclc />
  <header class="page-aside page-aside-left masthead">
    <h1>Lunar Pulse</h1>
    <p>The sky, kept as a clock.</p>
  </header>
  <div class="page-aside page-aside-right">
    <nav class="knights">
      <a href="/journal/">Lunation Journal</a>
      <a href="/circle/">Clairsentient Support Circle</a>
    </nav>
    <p class="snapshot">{skyNow}</p>
  </div>
  <script type="application/ld+json" is:inline set:html={ld} />
</Base>
