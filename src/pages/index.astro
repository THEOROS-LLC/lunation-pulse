---
import Base from '../layouts/Base.astro';
import Cclc from '../components/Cclc.astro';
import { getLunation } from '../cclc/lunation.js';
const L = getLunation(new Date());
const sunIn = L.sunLon % 30;
const sunSign = ['Aries','Taurus','Gemini','Cancer','Leo','Virgo','Libra','Scorpio','Sagittarius','Capricorn','Aquarius','Pisces'][Math.floor(L.sunLon / 30)];
const pad = n => String(n).padStart(2, '0');
const skyNow = `The Moon is at ${L.deg}°${pad(L.arcmin)}′ ${L.sign}, in its ${L.phase.toLowerCase()} phase, and the Sun stands at ${Math.floor(sunIn)}°${pad(Math.floor((sunIn % 1) * 60))}′ ${sunSign}. The clock keeps both positions to the arcminute, every second.`;
const built = new Date().toISOString();
const ld = JSON.stringify({
  '@context': 'https://schema.org',
  '@graph': [
    { '@type': 'WebSite', '@id': 'https://lunarpulse.ai/#site', name: 'Lunar Pulse',
      url: 'https://lunarpulse.ai/', description: 'The sky, kept as a clock.' },
    { '@type': 'Organization', '@id': 'https://lunarpulse.ai/#org', name: 'Lunar Pulse',
      url: 'https://lunarpulse.ai/' },
    { '@type': 'WebApplication', '@id': 'https://lunarpulse.ai/#app', name: 'Lunar Pulse',
      url: 'https://lunarpulse.ai/', applicationCategory: 'ReferenceApplication',
      operatingSystem: 'Any', isPartOf: { '@id': 'https://lunarpulse.ai/#site' },
      dateModified: built,
      description: 'A live lunation clock: the Moon\\u2019s zodiacal position, lunar phase, and the positions of Sun and Moon on the tropical zodiac, computed to the arcminute every second.' },
  ],
});
---
<Base title="Lunar Pulse — the living lunation clock">
  <div class="page-aside page-aside-top">
    <header class="masthead">
      <h1>Lunar Pulse</h1>
      <p>The sky, kept as a clock.</p>
    </header>
  </div>
  <Cclc />
  <div class="page-aside">
    <nav class="knights" aria-label="Pages">
      <a href="/journal/">Lunation Journal</a>
      <a href="/circle/">Clairsentient Support Circle</a>
    </nav>
    <section class="skynow">
      <p class="snapshot">{skyNow}</p>
    </section>
  </div>
  <script type="application/ld+json" is:inline set:html={ld} />
</Base>
