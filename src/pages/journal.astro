---
import Base from '../layouts/Base.astro';
import Cclc from '../components/Cclc.astro';
---
<Base title="The Lunation Journal — Lunar Pulse">
  <div id="journalPage" class="wheel-page">
    <div class="wheelwrap">
      <Cclc />
      <div id="room" class="room" aria-live="polite"></div>
    </div>
    <nav class="knights knights-under" aria-label="Pages">
      <a href="/expressions/">Lunar Expressions</a>
      <a href="/gathering/">The Gathering</a>
      <a href="/">The Clock</a>
    </nav>
  </div>
  <script>
    import { initJournal } from '../journal/journal.js';
    initJournal();
    document.addEventListener('astro:page-load', initJournal);
  </script>
</Base>
