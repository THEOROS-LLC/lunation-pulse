---
import Base from '../layouts/Base.astro';
import Cclc from '../components/Cclc.astro';
---
<Base title="Lunation Journal — Lunar Pulse">
  <div id="journalPage" class="circle-page">
    <Cclc />
    <div class="page-aside">
      <div id="room" aria-live="polite"></div>
      <nav class="knights" aria-label="Pages">
        <a href="/">The Clock</a>
        <a href="/circle/">Clairsentient Support Circle</a>
      </nav>
    </div>
  </div>
  <script>
    import { initJournal } from '../journal/journal.js';
    initJournal();
    document.addEventListener('astro:page-load', initJournal);
  </script>
</Base>
