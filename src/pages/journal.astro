---
import Base from '../layouts/Base.astro';
import Cclc from '../components/Cclc.astro';
---
<Base title="Lunation Journal \u2014 Lunar Pulse">
  <Cclc />
  <header class="page-aside page-aside-left masthead">
    <h1>Lunar Pulse</h1>
    <p>The Geometry of Natural Time in Real Time</p>
  </header>
  <div id="journalPage" class="page-aside page-aside-right">
    <div id="room" aria-live="polite"></div>
    <nav class="knights">
      <a href="/">The Clock</a>
      <a href="/circle/">Clairsentient Support Circle</a>
    </nav>
  </div>
  <script>
    import { initJournal } from '../journal/journal.js';
    initJournal();
    document.addEventListener('astro:page-load', initJournal);
  </script>
</Base>
