---
import Base from '../layouts/Base.astro';
import Cclc from '../components/Cclc.astro';
---
<Base title="Clairsentient Support Circle — Lunar Pulse">
  <Cclc />
  <header class="page-aside page-aside-left masthead">
    <h1>Lunar Pulse</h1>
    <p>The Geometry of Natural Time in Real Time</p>
  </header>
  <div id="circlePage" class="page-aside page-aside-right">
    <section id="locked" class="prose">
      <h2>Clairsentient Support Circle</h2>
      <p>The monthly circle meets under the living clock.</p>
      <form id="unlockForm" class="unlock">
        <input id="wordInput" type="password" placeholder="the circle word"
               autocomplete="off" aria-label="The circle word" required />
        <button type="submit" class="cta">Enter</button>
      </form>
      <p id="lockMsg" class="lockmsg" role="status"></p>
      <p class="joinline">Not yet a member? <a href="https://buy.stripe.com/28E28q2Okb1i8T44mYaZi00" rel="noopener">Join — $120/mo</a></p>
    </section>
    <section id="unlocked" hidden>
      <div id="nextGathering" class="gathering-hero" hidden aria-live="polite"></div>
      <div id="composerWrap" hidden>
        <form id="gComposer" class="composer">
          <p class="seals-legend">Announce the next gathering</p>
          <input id="gWhen" type="datetime-local" required aria-label="Meeting date and time" />
          <textarea id="gBody" rows="3" maxlength="2000" required
            placeholder="The announcement — theme, intention, what to bring inward."></textarea>
          <input id="gLink" type="url" maxlength="300" placeholder="the Zoom link" />
          <div class="composer-foot">
            <button type="submit" class="cta">Announce</button>
            <span id="gMsg" role="status"></span>
          </div>
        </form>
      </div>
      <h3 id="pastH" class="record-h" hidden>Gatherings</h3>
      <div id="pastList" class="record-list"></div>
    </section>
    <nav class="knights">
      <a href="/">The Clock</a>
      <a href="/journal/">Lunation Journal</a>
    </nav>
  </div>
  <script>
    import { initGathering } from '../circle/gathering.js';
    initGathering();
    document.addEventListener('astro:page-load', initGathering);
  </script>
</Base>
